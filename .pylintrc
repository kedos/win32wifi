[MASTER]
ignore=venv,tests,examples
load-plugins=

[MESSAGES CONTROL]
# Disabled messages — categorised by why they don't apply to this wrapper.
disable=
    # --- Docstring/naming: this package mirrors the Microsoft Native Wifi
    # API, where MSDN signatures are reproduced verbatim and naming follows
    # Win32 conventions (CamelCase, ALL_CAPS structs, Hungarian prefixes).
    C0114, # missing-module-docstring
    C0115, # missing-class-docstring
    C0116, # missing-function-docstring
    C0103, # invalid-name (Native API names often violate PEP8)
    C0301, # line-too-long (covered by ruff with line-length=140)
    C0302, # too-many-lines (Win32NativeWifiApi.py is a comprehensive binding)

    # --- Wildcard imports are intentional: ctypes brings in ~150 names that
    # the binding re-exports, and Win32Wifi pulls in the entire low-level
    # surface so that consumers can ``from Win32Wifi import *`` for parity
    # with the upstream PyWiWi API.
    W0401, # wildcard-import
    W0614, # unused-wildcard-import

    # --- ctypes Structure idiom: variable-length array fields (e.g.
    # ``DOT11_BSSID_LIST.uNumOfEntries``) are populated after instantiation
    # because their ``_fields_`` shape is fixed at class-creation time.
    W0201, # attribute-defined-outside-init

    # --- Architectural: the Win32 API has many wide structures and
    # multi-argument functions; redesigning them is out of scope.
    R0902, # too-many-instance-attributes
    R0903, # too-few-public-methods
    R0914, # too-many-locals
    R0917, # too-many-positional-arguments

    # --- Other intentional choices:
    W0511, # fixme (TODOs are tracked, shouldn't fail CI)
    W0703, # broad-except (sometimes needed in high-level wrappers)
    W0212, # protected-access (needed for some ctypes magic)

[REPORTS]
output-format=colorized

[DESIGN]
max-args=10
max-locals=20
max-returns=10
max-branches=15
max-statements=50

[TYPECHECK]
# List of members which are set dynamically and missed by pylint
generated-members=windll.*,POINTER.*,byref.*,addressof.*,pointer.*
