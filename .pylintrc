[MASTER]
ignore=venv,tests,examples
load-plugins=

[MESSAGES CONTROL]
# Disable specific messages that might be too noisy for this legacy wrapper
disable=
    C0114, # missing-module-docstring
    C0115, # missing-class-docstring
    C0116, # missing-function-docstring
    C0103, # invalid-name (Native API names often violate PEP8)
    R0903, # too-few-public-methods
    W0703, # broad-except (Sometimes needed in high-level wrappers)
    W0212, # protected-access (Needed for some ctypes magic)
    C0301, # line-too-long

[REPORTS]
output-format=colorized

[DESIGN]
max-args=10
max-locals=20
max-returns=10
max-branches=15
max-statements=50

[TYPECHECK]
# List of members which are set dynamically and missed by pylint
generated-members=windll.*,POINTER.*,byref.*,addressof.*,pointer.*
